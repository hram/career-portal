PORT=8000
DATABASE_URL=sqlite:////data/career-portal/career_portal.db
CAREER_PORTAL_UPLOAD_DIR=/data/career-portal/uploads

RESUME_PARSE_PROVIDER=claude-cli
CLAUDE_PARSE_TIMEOUT_SECONDS=300
CLAUDE_STEP_TIMEOUT_SECONDS=90
CODEX_MODEL=
CODEX_SANDBOX=read-only
CODEX_PARSE_TIMEOUT_SECONDS=600
CODEX_STEP_TIMEOUT_SECONDS=180
AI_AGENT_TIMEOUT_SECONDS=180

HH_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
HH_ACCESS_TOKEN=
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=

# Claude Code is installed in the production Docker image.
# Its auth files are expected under HOME/.claude.
HOME=/data/career-portal
CLAUDE_CLI_PATH=/usr/local/bin/claude
ANTHROPIC_API_KEY=

# Codex is not installed in the production image by default.
CODEX_CLI_PATH=codex
